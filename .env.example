# Copy to .env and fill in values (never commit .env)
#
# Use the SAME Supabase project as the POS app:
#   VITE_SUPABASE_URL      = EXPO_PUBLIC_SUPABASE_URL
#   VITE_SUPABASE_ANON_KEY = EXPO_PUBLIC_SUPABASE_ANON_KEY
# See docs/inventory-admin-alignment.md

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Default venue/org UUIDs (must match your Supabase seed data)
VITE_VENUE_ID=00000000-0000-0000-0000-000000000010
VITE_ORG_ID=00000000-0000-0000-0000-000000000001

# Floor plan: main hall zone UUID (must match zones row used by POS)
VITE_FLOOR_PLAN_ZONE_ID=00000000-0000-0000-0000-000000002001
# Optional: legacy zone to migrate orders away from (or omit)
VITE_LEGACY_ADMIN_ZONE_ID=00000000-0000-0000-0000-000000000100

# Set to "true" to require Supabase Auth login for all routes except /login
VITE_REQUIRE_AUTH=false
